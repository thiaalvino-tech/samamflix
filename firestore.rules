rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        currentUserDoc().data.role == 'admin'
      );
    }

    function isParticipant(resourceData) {
      return isSignedIn() &&
        resourceData.participantes is list &&
        request.auth.uid in resourceData.participantes;
    }

    function isCreatingOwnChatRoom() {
      return isSignedIn() &&
        request.resource.data.participantes is list &&
        request.resource.data.participantes.size() == 2 &&
        request.auth.uid in request.resource.data.participantes;
    }

    function isValidChatRoomCreate() {
      return isCreatingOwnChatRoom() &&
        request.resource.data.participantesOrdenados is string &&
        request.resource.data.participantesInfo is map;
    }

    function isValidChatRoomUpdate() {
      return isSignedIn() &&
        resource.data.participantes is list &&
        request.auth.uid in resource.data.participantes;
    }

    function parentRoom(roomId) {
      return get(/databases/$(database)/documents/chatRooms/$(roomId));
    }

    function canAccessRoom(roomId) {
      return isSignedIn() &&
        parentRoom(roomId).data.participantes is list &&
        request.auth.uid in parentRoom(roomId).data.participantes;
    }

    function isValidMessageCreate(roomId) {
      return canAccessRoom(roomId) &&
        request.resource.data.autorId == request.auth.uid &&
        request.resource.data.texto is string &&
        request.resource.data.texto.size() > 0 &&
        request.resource.data.texto.size() <= 1000;
    }

    match /usuarios/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /usuarios_publicos/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /comentarios/{comentarioId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
      );
    }

    match /historico_visualizacoes/{itemId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
      );
    }

    match /emotionAnalytics/{itemId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
      );
    }

    match /chatRooms/{roomId} {
      allow read: if isAdmin() || isParticipant(resource.data);
      allow create: if isAdmin() || isValidChatRoomCreate();
      allow update: if isAdmin() || isValidChatRoomUpdate();
      allow delete: if isAdmin();

      match /mensagens/{mensagemId} {
        allow read: if isAdmin() || canAccessRoom(roomId);

        allow create: if isAdmin() || isValidMessageCreate(roomId);

        allow update: if isAdmin() || (
          canAccessRoom(roomId) &&
          resource.data.autorId == request.auth.uid
        );

        allow delete: if isAdmin() || (
          canAccessRoom(roomId) &&
          resource.data.autorId == request.auth.uid
        );
      }
    }
  }
}
